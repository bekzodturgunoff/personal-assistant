{
  "name": "octopos-bot",
  "version": "1.0.0",
  "description": "Octopos Telegram Bot - AI team member & GitHub webhook notifier",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "deploy:cloudflare": "npx wrangler deploy",
    "dev:cloudflare": "npx wrangler dev"
  },
  "dependencies": {
    "@google/genai": "^1.3.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.34.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
